   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## How to Use the Model Locally\n",
    "\n",
    "After downloading the model:\n",
    "\n",
    "1. **Extract** the zip file to `edna_pipeline/models/dnabert2_16s/`\n",
    "\n",
    "2. **Use** the model in your pipeline by loading tokenizer + custom model class\n",
    "\n",
    "Example inference code:\n",
    "```python\n",
    "import json\n",
    "import pickle\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from transformers import AutoTokenizer, AutoModel, AutoConfig\n",
    "\n",
    "model_dir = 'edna_pipeline/models/dnabert2_16s_species/'\n",
    "\n",
    "with open(model_dir + 'model_info.json', 'r') as f:\n",
    "    model_info = json.load(f)\n",
    "\n",
    "with open(model_dir + 'label_encoder.pkl', 'rb') as f:\n",
    "    label_encoder = pickle.load(f)\n",
    "\n",
    "base_model = model_info['base_model']\n",
    "num_classes = model_info['num_classes']\n",
    "max_length = model_info['max_length']\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(model_dir, trust_remote_code=True)\n",
    "config = AutoConfig.from_pretrained(base_model, trust_remote_code=True)\n",
    "if (not hasattr(config, 'pad_token_id')) or (config.pad_token_id is None):\n",
    "    config.pad_token_id = tokenizer.pad_token_id if tokenizer.pad_token_id is not None else 0\n",
    "\n",
    "class DNABERT2ForTaxonomy(nn.Module):\n",
    "    def __init__(self, base_model, num_labels, tokenizer, config):\n",
    "        super().__init__()\n",
    "        self.encoder = AutoModel.from_pretrained(base_model, config=config, trust_remote_code=True)\n",
    "        emb = self.encoder.get_input_embeddings()\n",
    "        if emb is not None and len(tokenizer) > emb.num_embeddings:\n",
    "            self.encoder.resize_token_embeddings(len(tokenizer))\n",
    "        hidden_size = getattr(self.encoder.config, 'hidden_size', 768)\n",
    "        self.dropout = nn.Dropout(0.1)\n",
    "        self.classifier = nn.Linear(hidden_size, num_labels)\n",
    "\n",
    "    def forward(self, input_ids=None, attention_mask=None):\n",
    "        out = self.encoder(input_ids=input_ids, attention_mask=attention_mask, return_dict=True)\n",
    "        pooled = out.pooler_output if getattr(out, 'pooler_output', None) is not None else out.last_hidden_state[:, 0, :]\n",
    "        return self.classifier(self.dropout(pooled))\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "model = DNABERT2ForTaxonomy(base_model, num_classes, tokenizer, config).to(device)\n",
    "state_dict = torch.load(model_dir + 'model_state.pt', map_location=device)\n",
    "model.load_state_dict(state_dict)\n",
    "model.eval()\n",
    "\n",
    "def predict(sequence):\n",
    "    inputs = tokenizer(sequence, return_tensors='pt', truncation=True, max_length=max_length, padding=True)\n",
    "    inputs = {k: v.to(device) for k, v in inputs.items()}\n",
    "    with torch.no_grad():\n",
    "        logits = model(**inputs)\n",
    "    probs = torch.softmax(logits, dim=-1)\n",
    "    pred_idx = int(torch.argmax(probs, dim=-1).item())\n",
    "    confidence = float(torch.max(probs).item())\n",
    "    pred_species = label_encoder.inverse_transform([pred_idx])[0]\n",
    "    return pred_species, confidence\n",
    "```"
   ]
