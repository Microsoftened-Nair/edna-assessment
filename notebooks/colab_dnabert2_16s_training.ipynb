    "## Step 3: Download NCBI 16S Database & Taxonomy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import subprocess\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Working directory\n",
    "WORK_DIR = '/content/16s_data'\n",
    "os.makedirs(WORK_DIR, exist_ok=True)\n",
    "os.chdir(WORK_DIR)\n",
    "\n",
    "print(\"Downloading NCBI 16S rRNA database...\")\n",
    "!wget -q -N https://ftp.ncbi.nlm.nih.gov/blast/db/16S_ribosomal_RNA.tar.gz\n",
    "\n",
    "print(\"Downloading NCBI taxonomy dump...\")\n",
    "!wget -q -N https://ftp.ncbi.nlm.nih.gov/pub/taxonomy/taxdump.tar.gz\n",
    "\n",
    "print(\"Extracting databases...\")\n",
    "!tar -xzf 16S_ribosomal_RNA.tar.gz\n",
    "!tar -xzf taxdump.tar.gz\n",
    "\n",
    "print(\"Setup complete!\")\n",
    "!ls -la"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4: Extract Sequences with TaxIDs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract accession, TaxID, title, and sequence in tabular form\n",
    "# Using subprocess (instead of !cmd) so failures are not silently ignored\n",
    "import os\n",
    "import subprocess\n",
    "\n",
    "print(\"Extracting sequences + TaxIDs from BLAST database...\")\n",
    "out_tsv = '16S_taxid_sequences.tsv'\n",
    "cmd = [\n",
    "    'blastdbcmd',\n",
    "    '-db', '16S_ribosomal_RNA',\n",
    "    '-entry', 'all',\n",
    "    '-outfmt', '%a\\t%T\\t%t\\t%s',\n",
    "]\n",
    "\n",
    "with open(out_tsv, 'w') as out_f:\n",
    "    proc = subprocess.run(cmd, stdout=out_f, stderr=subprocess.PIPE, text=True)\n",
    "\n",
    "if proc.returncode != 0:\n",
    "    raise RuntimeError(\n",
    "        'blastdbcmd failed while extracting 16S data.\\n'\n",
    "        f'Command: {\" \\".join(cmd)}\\n'\n",
    "        f'STDERR: {proc.stderr}'\n",
    "    )\n",
    "\n",
    "if (not os.path.exists(out_tsv)) or os.path.getsize(out_tsv) == 0:\n",
    "    raise RuntimeError(\n",
    "        'Extraction produced an empty TSV.\\n'\n",
    "        'Likely causes: wrong DB path/name, corrupted DB, or missing taxonomy mapping in DB.'\n",
    "    )\n",
    "\n",
    "print(\"Extraction complete!\")\n",
    "!wc -l 16S_taxid_sequences.tsv\n",
    "!head -n 3 16S_taxid_sequences.tsv"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 5: Parse Taxonomy from NCBI Taxdump"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from collections import defaultdict\n",
    "\n",
    "print(\"Parsing NCBI taxonomy...\")\n",
    "\n",
    "# Parse nodes.dmp (taxonomy tree)\n",
    "nodes = {}\n",
    "with open('nodes.dmp', 'r') as f:\n",
    "    for line in f:\n",
    "        parts = line.split('|')\n",
    "        tax_id = int(parts[0].strip())\n",
    "        parent_id = int(parts[1].strip())\n",
    "        rank = parts[2].strip()\n",
    "        nodes[tax_id] = {'parent': parent_id, 'rank': rank}\n",
    "\n",
    "print(f\"Loaded {len(nodes)} taxonomy nodes\")\n",
    "\n",
    "# Parse names.dmp (scientific names)\n",
    "names = {}\n",
    "with open('names.dmp', 'r') as f:\n",
    "    for line in f:\n",
    "        parts = line.split('|')\n",
    "        tax_id = int(parts[0].strip())\n",
    "        name = parts[1].strip()\n",
    "        name_class = parts[3].strip()\n",
    "        if name_class == 'scientific name':\n",
    "            names[tax_id] = name\n",
    "\n",
    "print(f\"Loaded {len(names)} scientific names\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build lineage lookup function\n",
    "RANKS = ['superkingdom', 'phylum', 'class', 'order', 'family', 'genus', 'species']\n",
    "OUTPUT_RANKS = ['kingdom', 'phylum', 'class', 'order', 'family', 'genus', 'species']\n",
    "RANK_MAP = {'superkingdom': 'kingdom'}\n",
    "ROOT_TAXID = 1\n",
    "\n",
    "def get_lineage(tax_id):\n",
    "    \"\"\"Get full taxonomy lineage for a TaxID\"\"\"\n",
    "    result = {rank: 'Unknown' for rank in OUTPUT_RANKS}\n",
    "    \n",
    "    if tax_id not in nodes:\n",
    "        return result\n",
    "    \n",
    "    current = tax_id\n",
    "    visited = set()\n",
    "    \n",
    "    while current != ROOT_TAXID:\n",
    "        if current in visited:\n",
    "            break\n",
    "        visited.add(current)\n",
    "        \n",
    "        if current not in nodes:\n",
    "            break\n",
    "        \n",
    "        node = nodes[current]\n",
    "        rank = node['rank']\n",
    "        parent = node['parent']\n",
    "        \n",
    "        if rank in RANKS:\n",
    "            key = RANK_MAP.get(rank, rank)\n",
    "            if result[key] == 'Unknown' and current in names:\n",
    "                result[key] = names[current]\n",
    "        \n",
    "        if parent == current:\n",
    "            break\n",
    "        current = parent\n",
    "    \n",
    "    return result\n",
    "\n",
    "# Test\n",
    "test_lineage = get_lineage(562)  # E. coli\n",
    "print(\"Test lineage for TaxID 562 (E. coli):\", test_lineage)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 6: Parse Sequences and Map to Taxonomy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "\n",
    "print(\"Parsing extracted TSV and mapping taxonomy...\")\n",
    "\n",
    "# TSV columns: accession, taxid, title, sequence\n",
    "df_raw = pd.read_csv(\n",
    "    '16S_taxid_sequences.tsv',\n",
    "    sep='\\t',\n",
    "    header=None,\n",
    "    names=['id', 'taxid', 'title', 'sequence'],\n",
    "    dtype={'id': str, 'taxid': 'Int64', 'title': str, 'sequence': str},\n",
    "    keep_default_na=False\n",
    ")\n",
    "\n",
    "if df_raw.empty:\n",
    "    raise RuntimeError(\n",
    "        '16S_taxid_sequences.tsv is empty. Re-run extraction cell and inspect blastdbcmd STDERR.'\n",
    "    )\n",
    "\n",
    "print(f\"Extracted rows: {len(df_raw)}\")\n",
    "\n",
    "# Drop invalid rows\n",
    "df_raw = df_raw[df_raw['taxid'].notna()]\n",
    "df_raw = df_raw[df_raw['taxid'] > 0]\n",
    "df_raw = df_raw[df_raw['sequence'].str.len() > 0]\n",
    "df_raw['taxid'] = df_raw['taxid'].astype(int)\n",
    "\n",
    "if df_raw.empty:\n",
    "    raise RuntimeError(\n",
    "        'No valid TaxIDs found after parsing.\\n'\n",
    "        'If this is a custom BLAST DB without taxonomy links, use a DB built with taxids or switch to title-based labels.'\n",
    "    )\n",
    "\n",
    "print(f\"Rows with valid TaxID + sequence: {len(df_raw)}\")\n",
    "\n",
    "# Resolve lineage with cache for speed\n",
    "lineage_cache = {}\n",
    "sequences_data = []\n",
    "for row in df_raw.itertuples(index=False):\n",
    "    taxid = int(row.taxid)\n",
    "    if taxid not in lineage_cache:\n",
    "        lineage_cache[taxid] = get_lineage(taxid)\n",
    "\n",
    "    sequences_data.append({\n",
    "        'id': row.id,\n",
    "        'sequence': str(row.sequence).upper(),\n",
    "        'taxid': taxid,\n",
    "        **lineage_cache[taxid],\n",
    "    })\n",
    "\n",
    "print(f\"Parsed {len(sequences_data)} sequences with taxonomy\")\n",
    "\n",
    "df = pd.DataFrame(sequences_data)\n",
    "if df.empty:\n",
    "    raise RuntimeError('No sequences were mapped to taxonomy. Check taxdump files and TaxID extraction.')\n",
    "\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 7: Data Cleaning & Filtering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "\n",
    "print(f\"Initial sequences: {len(df)}\")\n",
    "\n",
    "# Filter 1: Valid nucleotides only (A, T, G, C)\n",
    "def is_valid_dna(seq):\n",
    "    return bool(re.match(r'^[ATGC]+$', seq))\n",
    "\n",
    "df = df[df['sequence'].apply(is_valid_dna)]\n",
    "print(f\"After valid DNA filter: {len(df)}\")\n",
    "\n",
    "# Filter 2: Length check (200-2000bp typical for 16S)\n",
    "df = df[(df['sequence'].str.len() >= 200) & (df['sequence'].str.len() <= 2000)]\n",
    "print(f\"After length filter (200-2000bp): {len(df)}\")\n",
    "\n",
    "# Filter 3: Must have species-level taxonomy\n",
    "df = df[df['species'] != 'Unknown']\n",
    "print(f\"After species-level filter: {len(df)}\")\n",
    "\n",
    "# Show taxonomy distribution\n",
    "print(f\"\\nUnique species: {df['species'].nunique()}\")\n",
    "print(f\"Unique genera: {df['genus'].nunique()}\")\n",
    "print(f\"Unique families: {df['family'].nunique()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 8: Subsample for Training (50K sequences)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build a meaningful species-level dataset (avoid 1 sample/class collapse)\n",
    "TARGET_SIZE = 50000\n",
    "MIN_SAMPLES_PER_SPECIES = 10\n",
    "MAX_SPECIES_CLASSES = 2000\n",
    "MAX_SAMPLES_PER_SPECIES = 64\n",
    "RANDOM_STATE = 42\n",
    "\n",
    "species_counts = df['species'].value_counts()\n",
    "eligible_species = species_counts[species_counts >= MIN_SAMPLES_PER_SPECIES].index\n",
    "df_filtered = df[df['species'].isin(eligible_species)].copy()\n",
    "\n",
    "print(f\"Species before filtering: {df['species'].nunique()}\")\n",
    "print(f\"Species with >= {MIN_SAMPLES_PER_SPECIES} samples: {len(eligible_species)}\")\n",
    "print(f\"Rows after min-samples filter: {len(df_filtered)}\")\n",
    "\n",
    "if df_filtered.empty:\n",
    "    raise RuntimeError(\n",
    "        'No species have enough samples for meaningful training. '\n",
    "        'Reduce MIN_SAMPLES_PER_SPECIES or increase source data.'\n",
    "    )\n",
    "\n",
    "# Keep most represented species to keep class count tractable on T4\n",
    "if df_filtered['species'].nunique() > MAX_SPECIES_CLASSES:\n",
    "    top_species = df_filtered['species'].value_counts().head(MAX_SPECIES_CLASSES).index\n",
    "    df_filtered = df_filtered[df_filtered['species'].isin(top_species)].copy()\n",
    "\n",
    "# Cap per-species samples to reduce severe imbalance\n",
    "df_balanced = (\n",
    "    df_filtered.groupby('species', group_keys=False)\n",
    "    .apply(lambda g: g.sample(n=min(len(g), MAX_SAMPLES_PER_SPECIES), random_state=RANDOM_STATE))\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "# Keep approximately balanced dataset near TARGET_SIZE\n",
    "n_species = df_balanced['species'].nunique()\n",
    "per_species_target = max(1, TARGET_SIZE // n_species)\n",
    "\n",
    "df_core = (\n",
    "    df_balanced.groupby('species', group_keys=False)\n",
    "    .apply(lambda g: g.sample(n=min(len(g), per_species_target), random_state=RANDOM_STATE))\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "if len(df_core) < TARGET_SIZE:\n",
    "    remaining = df_balanced.drop(df_core.index, errors='ignore')\n",
    "    need = TARGET_SIZE - len(df_core)\n",
    "    if len(remaining) > 0:\n",
    "        extra = remaining.sample(n=min(need, len(remaining)), random_state=RANDOM_STATE)\n",
    "        df_sampled = pd.concat([df_core, extra], ignore_index=True)\n",
    "    else:\n",
    "        df_sampled = df_core\n",
    "else:\n",
    "    df_sampled = df_core.sample(n=TARGET_SIZE, random_state=RANDOM_STATE) if len(df_core) > TARGET_SIZE else df_core\n",
    "\n",
    "df_sampled = df_sampled.sample(frac=1.0, random_state=RANDOM_STATE).reset_index(drop=True)\n",
    "\n",
    "final_counts = df_sampled['species'].value_counts()\n",
    "print(f\"\\nFinal training pool size: {len(df_sampled)}\")\n",
    "print(f\"Unique species: {df_sampled['species'].nunique()}\")\n",
    "print(f\"Min/median/max samples per species: {final_counts.min()}/{int(final_counts.median())}/{final_counts.max()}\")\n",
    "print(\"\\nTop 10 species in final pool:\")\n",
    "print(final_counts.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 9: Prepare Training Data Format"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "import pickle\n",
    "\n",
    "df_sampled = df_sampled.reset_index(drop=True)\n",
    "\n",
    "# Stratified split so every class distribution is represented\n",
    "train_df, temp_df = train_test_split(\n",
    "    df_sampled,\n",
    "    test_size=0.2,\n",
    "    random_state=42,\n",
    "    stratify=df_sampled['species']\n",
    ")\n",
    "\n",
    "val_df, test_df = train_test_split(\n",
    "    temp_df,\n",
    "    test_size=0.5,\n",
    "    random_state=42,\n",
    "    stratify=temp_df['species']\n",
    ")\n",
    "\n",
    "# Fit encoder on train labels only (no leakage)\n",
    "label_encoder = LabelEncoder()\n",
    "label_encoder.fit(train_df['species'])\n",
    "\n",
    "# Guard: val/test must not contain unseen classes\n",
    "train_species = set(train_df['species'])\n",
    "for split_name, split_df in [('val', val_df), ('test', test_df)]:\n",
    "    unseen = set(split_df['species']) - train_species\n",
    "    if unseen:\n",
    "        raise RuntimeError(f\"{split_name} split has {len(unseen)} unseen classes. Increase per-class minimum.\")\n",
    "\n",
    "print(f\"Train: {len(train_df)}, Val: {len(val_df)}, Test: {len(test_df)}\")\n",
    "print(f\"Classes in train: {len(label_encoder.classes_)}\")\n",
    "print(f\"Train min samples/class: {train_df['species'].value_counts().min()}\")\n",
    "\n",
    "# Save splits and encoder\n",
    "train_df.to_csv(f'{WORK_DIR}/train_data.csv', index=False)\n",
    "val_df.to_csv(f'{WORK_DIR}/val_data.csv', index=False)\n",
    "test_df.to_csv(f'{WORK_DIR}/test_data.csv', index=False)\n",
    "with open(f'{WORK_DIR}/label_encoder.pkl', 'wb') as f:\n",
    "    pickle.dump(label_encoder, f)\n",
    "\n",
    "print('Data saved!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 10: Fine-tune DNABERT-2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from transformers import AutoTokenizer, AutoModel, AutoConfig\n",
    "from transformers import Trainer, TrainingArguments\n",
    "from transformers.modeling_outputs import SequenceClassifierOutput\n",
    "from torch.utils.data import Dataset\n",
    "import numpy as np\n",
    "\n",
    "# Check GPU\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Using device: {device}\")\n",
    "\n",
    "MODEL_NAME = \"zhihan1996/DNABERT-2-117M\"\n",
    "HF_TOKEN = os.getenv('HF_TOKEN')\n",
    "NUM_CLASSES = len(label_encoder.classes_)\n",
    "\n",
    "print(\"Loading DNABERT-2 tokenizer/config...\")\n",
    "tokenizer = AutoTokenizer.from_pretrained(\n",
    "    MODEL_NAME, token=HF_TOKEN, trust_remote_code=True\n",
    ")\n",
    "\n",
    "# Ensure pad token exists\n",
    "if tokenizer.pad_token_id is None:\n",
    "    if tokenizer.eos_token is not None:\n",
    "        tokenizer.pad_token = tokenizer.eos_token\n",
    "    elif tokenizer.sep_token is not None:\n",
    "        tokenizer.pad_token = tokenizer.sep_token\n",
    "    else:\n",
    "        tokenizer.add_special_tokens({'pad_token': '[PAD]'})\n",
    "\n",
    "config = AutoConfig.from_pretrained(\n",
    "    MODEL_NAME, token=HF_TOKEN, trust_remote_code=True\n",
    ")\n",
    "if (not hasattr(config, 'pad_token_id')) or (config.pad_token_id is None):\n",
    "    config.pad_token_id = tokenizer.pad_token_id if tokenizer.pad_token_id is not None else 0\n",
    "\n",
    "class DNABERT2ForTaxonomy(nn.Module):\n",
    "    def __init__(self, model_name, num_labels, tokenizer, config, token=None):\n",
    "        super().__init__()\n",
    "        self.encoder = AutoModel.from_pretrained(\n",
    "            model_name, config=config, token=token, trust_remote_code=True\n",
    "        )\n",
    "\n",
    "        emb = self.encoder.get_input_embeddings()\n",
    "        if emb is not None and len(tokenizer) > emb.num_embeddings:\n",
    "            self.encoder.resize_token_embeddings(len(tokenizer))\n",
    "\n",
    "        hidden_size = getattr(self.encoder.config, 'hidden_size', 768)\n",
    "        self.dropout = nn.Dropout(0.1)\n",
    "        self.classifier = nn.Linear(hidden_size, num_labels)\n",
    "\n",
    "    def forward(self, input_ids=None, attention_mask=None, labels=None):\n",
    "        out = self.encoder(\n",
    "            input_ids=input_ids, attention_mask=attention_mask, return_dict=True\n",
    "        )\n",
    "\n",
    "        if getattr(out, 'pooler_output', None) is not None:\n",
    "            pooled = out.pooler_output\n",
    "        else:\n",
    "            pooled = out.last_hidden_state[:, 0, :]\n",
    "\n",
    "        logits = self.classifier(self.dropout(pooled))\n",
    "        loss = F.cross_entropy(logits, labels) if labels is not None else None\n",
    "        return SequenceClassifierOutput(loss=loss, logits=logits)\n",
    "\n",
    "model = DNABERT2ForTaxonomy(MODEL_NAME, NUM_CLASSES, tokenizer, config, token=HF_TOKEN).to(device)\n",
    "print(\"Model loaded!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create Dataset class\n",
    "class DNADataset(Dataset):\n",
    "    def __init__(self, dataframe, tokenizer, max_length=512):\n",
    "        self.data = dataframe\n",
    "        self.tokenizer = tokenizer\n",
    "        self.max_length = max_length\n",
    "    \n",
    "    def __len__(self):\n",
    "        return len(self.data)\n",
    "    \n",
    "    def __getitem__(self, idx):\n",
    "        row = self.data.iloc[idx]\n",
    "        sequence = row['sequence'][:self.max_length]  # Truncate if too long\n",
    "        \n",
    "        encoding = self.tokenizer(\n",
    "            sequence,\n",
    "            truncation=True,\n",
    "            max_length=self.max_length,\n",
    "            padding='max_length',\n",
    "            return_tensors='pt'\n",
    "        )\n",
    "        \n",
    "        label = label_encoder.transform([row['species']])[0]\n",
    "        \n",
    "        return {\n",
    "            'input_ids': encoding['input_ids'].squeeze(),\n",
    "            'attention_mask': encoding['attention_mask'].squeeze(),\n",
    "            'labels': torch.tensor(label, dtype=torch.long)\n",
    "        }\n",
    "\n",
